{
  "definitions": {
    "sap.capire.travels.flights.FlightSchedules": {
      "kind": "entity",
      "includes": [
        "managed"
      ],
      "elements": {
        "flight": {
          "key": true,
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.FlightConnections"
        },
        "date": {
          "key": true,
          "type": "cds.Date"
        },
        "aircraft": {
          "type": "cds.String"
        },
        "price": {
          "type": "cds.Decimal",
          "precision": 9,
          "scale": 4
        },
        "currency": {
          "type": "Currency"
        },
        "maximum_seats": {
          "type": "cds.Integer"
        },
        "occupied_seats": {
          "type": "cds.Integer"
        },
        "free_seats": {
          "type": "cds.Integer",
          "value": {
            "xpr": [
              {
                "ref": [
                  "maximum_seats"
                ]
              },
              "-",
              {
                "ref": [
                  "occupied_seats"
                ]
              }
            ]
          }
        }
      }
    },
    "sap.capire.travels.flights.Flights": {
      "kind": "entity",
      "@title": "{i18n>Flight}",
      "query": {
        "SELECT": {
          "from": {
            "ref": [
              "sap.capire.travels.flights.FlightSchedules"
            ]
          },
          "columns": [
            {
              "@title": "{i18n>FlightID}",
              "key": true,
              "ref": [
                "flight",
                "ID"
              ],
              "as": "ID"
            },
            {
              "@title": "{i18n>FlightDate}",
              "key": true,
              "ref": [
                "date"
              ]
            },
            {
              "ref": [
                "aircraft"
              ]
            },
            {
              "ref": [
                "price"
              ]
            },
            {
              "ref": [
                "currency"
              ]
            },
            {
              "ref": [
                "maximum_seats"
              ]
            },
            {
              "ref": [
                "occupied_seats"
              ]
            },
            {
              "@title": "{i18n>MaximumSeats}",
              "ref": [
                "free_seats"
              ]
            },
            {
              "ref": [
                "modifiedAt"
              ]
            },
            {
              "@UI.IsImageURL": true,
              "ref": [
                "flight",
                "airline",
                "icon"
              ],
              "as": "icon"
            },
            {
              "@Common.ValueList.CollectionPath": "Airline",
              "@Common.ValueList.Label": "",
              "@Common.ValueList.Parameters": [
                {
                  "$Type": "Common.ValueListParameterInOut",
                  "LocalDataProperty": {
                    "=": "AirlineID"
                  },
                  "ValueListProperty": "AirlineID"
                },
                {
                  "$Type": "Common.ValueListParameterDisplayOnly",
                  "ValueListProperty": "Name"
                },
                {
                  "$Type": "Common.ValueListParameterDisplayOnly",
                  "ValueListProperty": "Currency"
                }
              ],
              "@title": "{i18n>Name}",
              "ref": [
                "flight",
                "airline",
                "name"
              ],
              "as": "airline"
            },
            {
              "@title": "{i18n>Origin}",
              "ref": [
                "flight",
                "origin",
                "name"
              ],
              "as": "origin"
            },
            {
              "@title": "{i18n>Destination}",
              "ref": [
                "flight",
                "destination",
                "name"
              ],
              "as": "destination"
            },
            {
              "@title": "{i18n>DepartureTime}",
              "ref": [
                "flight",
                "departure"
              ],
              "as": "departure"
            },
            {
              "@title": "{i18n>ArrivalTime}",
              "ref": [
                "flight",
                "arrival"
              ],
              "as": "arrival"
            }
          ]
        }
      }
    },
    "sap.capire.travels.flights.FlightConnections": {
      "kind": "entity",
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.String",
          "length": 11
        },
        "airline": {
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.Airlines"
        },
        "origin": {
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.Airports"
        },
        "destination": {
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.Airports"
        },
        "departure": {
          "type": "cds.Time"
        },
        "arrival": {
          "type": "cds.Time"
        },
        "distance": {
          "type": "cds.Integer"
        }
      }
    },
    "sap.capire.travels.flights.Airlines": {
      "kind": "entity",
      "includes": [
        "cuid",
        "managed"
      ],
      "elements": {
        "name": {
          "type": "cds.String"
        },
        "icon": {
          "type": "cds.String"
        },
        "currency": {
          "type": "Currency"
        },
        "flights": {
          "type": "cds.Association",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.capire.travels.flights.FlightConnections",
          "on": [
            {
              "ref": [
                "flights",
                "airline"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
    "sap.capire.travels.flights.Airports": {
      "kind": "entity",
      "includes": [
        "cuid",
        "managed"
      ],
      "elements": {
        "name": {
          "type": "cds.String"
        },
        "city": {
          "type": "cds.String"
        },
        "country": {
          "type": "Country"
        },
        "arrivals": {
          "type": "cds.Association",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.capire.travels.flights.FlightConnections",
          "on": [
            {
              "ref": [
                "arrivals",
                "destination"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "departures": {
          "type": "cds.Association",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.capire.travels.flights.FlightConnections",
          "on": [
            {
              "ref": [
                "departures",
                "origin"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
    "sap.capire.travels.flights.Supplements": {
      "kind": "entity",
      "@title": "{i18n>Supplement}",
      "includes": [
        "cuid",
        "managed"
      ],
      "elements": {
        "type": {
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.SupplementTypes"
        },
        "descr": {
          "@title": "{i18n>Description}",
          "localized": true,
          "type": "cds.String",
          "length": 1111
        },
        "price": {
          "@title": "{i18n>Price}",
          "@Measures.ISOCurrency": {
            "=": "currency_code"
          },
          "type": "cds.Decimal",
          "precision": 9,
          "scale": 4
        },
        "currency": {
          "@title": "{i18n>CurrencyCode}",
          "type": "Currency"
        }
      }
    },
    "sap.capire.travels.flights.SupplementTypes": {
      "kind": "entity",
      "includes": [
        "sap.common.CodeList"
      ],
      "elements": {
        "code": {
          "key": true,
          "type": "cds.String",
          "length": 2,
          "enum": {
            "Beverage": {
              "val": "BV"
            },
            "Meal": {
              "val": "ML"
            },
            "Luggage": {
              "val": "LU"
            },
            "Extra": {
              "val": "EX"
            }
          }
        }
      }
    },
    "sap.common.countries.Regions": {
      "kind": "entity",
      "includes": [
        "sap.common.CodeList"
      ],
      "elements": {
        "code": {
          "key": true,
          "type": "cds.String",
          "length": 5
        },
        "children": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.common.countries.Regions",
          "on": [
            {
              "ref": [
                "children",
                "_parent"
              ]
            },
            "=",
            {
              "ref": [
                "$self",
                "code"
              ]
            }
          ]
        },
        "cities": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.common.countries.Cities",
          "on": [
            {
              "ref": [
                "cities",
                "region"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        },
        "_parent": {
          "type": "cds.String",
          "length": 11
        }
      }
    },
    "sap.common.countries.Cities": {
      "kind": "entity",
      "includes": [
        "sap.common.CodeList"
      ],
      "elements": {
        "code": {
          "key": true,
          "type": "cds.String",
          "length": 11
        },
        "region": {
          "type": "cds.Association",
          "target": "sap.common.countries.Regions"
        },
        "districts": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.common.countries.Districts",
          "on": [
            {
              "ref": [
                "districts",
                "city"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
    "sap.common.countries.Districts": {
      "kind": "entity",
      "includes": [
        "sap.common.CodeList"
      ],
      "elements": {
        "code": {
          "key": true,
          "type": "cds.String",
          "length": 11
        },
        "city": {
          "type": "cds.Association",
          "target": "sap.common.countries.Cities"
        }
      }
    },
    "sap.capire.travels.Price": {
      "kind": "type",
      "type": "cds.Decimal",
      "precision": 9,
      "scale": 4
    },
    "sap.capire.travels.Travels": {
      "kind": "entity",
      "@title": "{i18n>Travel}",
      "includes": [
        "managed"
      ],
      "elements": {
        "ID": {
          "@readonly": true,
          "@title": "{i18n>Travel}",
          "key": true,
          "type": "cds.Integer"
        },
        "Description": {
          "@title": "{i18n>Description}",
          "type": "cds.String",
          "length": 1024
        },
        "BeginDate": {
          "@title": "{i18n>BeginDate}",
          "type": "cds.Date",
          "default": {
            "ref": [
              "$now"
            ]
          }
        },
        "EndDate": {
          "@title": "{i18n>EndDate}",
          "type": "cds.Date",
          "default": {
            "ref": [
              "$now"
            ]
          }
        },
        "BookingFee": {
          "@title": "{i18n>BookingFee}",
          "@Measures.ISOCurrency": {
            "=": "Currency_code"
          },
          "type": "sap.capire.travels.Price",
          "default": {
            "val": 0
          }
        },
        "TotalPrice": {
          "@readonly": true,
          "@title": "{i18n>TotalPrice}",
          "@Measures.ISOCurrency": {
            "=": "Currency_code"
          },
          "type": "sap.capire.travels.Price"
        },
        "Currency": {
          "@Common.ValueList.CollectionPath": "Currencies",
          "@Common.ValueList.Label": "",
          "@Common.ValueList.Parameters": [
            {
              "$Type": "Common.ValueListParameterInOut",
              "LocalDataProperty": {
                "=": "Currency_code"
              },
              "ValueListProperty": "code"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "name"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "descr"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "symbol"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "minor"
            }
          ],
          "type": "Currency",
          "default": {
            "val": "EUR"
          }
        },
        "Status": {
          "@Common.ValueListWithFixedValues": true,
          "@title": "{i18n>TravelStatus}",
          "@Common.Text": {
            "=": "Status.name"
          },
          "@Common.TextArrangement": {
            "#": "TextOnly"
          },
          "type": "cds.Association",
          "target": "sap.capire.travels.TravelStatus",
          "default": {
            "val": "O"
          }
        },
        "Agency": {
          "@Common.ValueList.CollectionPath": "TravelAgencies",
          "@Common.ValueList.Label": "",
          "@Common.ValueList.Parameters": [
            {
              "$Type": "Common.ValueListParameterInOut",
              "LocalDataProperty": {
                "=": "Agency_ID"
              },
              "ValueListProperty": "ID"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "Name"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "Street"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "PostalCode"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "City"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "CountryCode_code"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "PhoneNumber"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "EMailAddress"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "WebAddress"
            }
          ],
          "@title": "{i18n>Agency}",
          "@Common.Text": {
            "=": "Agency.Name"
          },
          "@Common.TextArrangement": {
            "#": "TextOnly"
          },
          "type": "cds.Association",
          "target": "sap.capire.travels.TravelAgencies"
        },
        "Customer": {
          "@Common.ValueList.CollectionPath": "Customers",
          "@Common.ValueList.Label": "Customer ID",
          "@Common.ValueList.Parameters": [
            {
              "$Type": "Common.ValueListParameterInOut",
              "LocalDataProperty": {
                "=": "Customer_ID"
              },
              "ValueListProperty": "ID"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "Name"
            }
          ],
          "@title": "{i18n>Customer}",
          "@Common.Text": {
            "=": "Customer.Name"
          },
          "@Common.TextArrangement": {
            "#": "TextOnly"
          },
          "type": "cds.Association",
          "target": "sap.capire.travels.Customers"
        },
        "Bookings": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.capire.travels.Bookings",
          "on": [
            {
              "ref": [
                "Bookings",
                "Travel"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
    "sap.capire.travels.Bookings": {
      "kind": "entity",
      "@title": "{i18n>Booking}",
      "elements": {
        "Travel": {
          "@UI.Hidden": true,
          "key": true,
          "type": "cds.Association",
          "target": "sap.capire.travels.Travels"
        },
        "Pos": {
          "@readonly": true,
          "@title": "{i18n>BookingID}",
          "key": true,
          "type": "cds.Integer"
        },
        "Flight": {
          "@title": "{i18n>Flight}",
          "type": "cds.Association",
          "target": "sap.capire.travels.flights.Flights"
        },
        "FlightPrice": {
          "@title": "{i18n>FlightPrice}",
          "@Measures.ISOCurrency": {
            "=": "Currency_code"
          },
          "type": "sap.capire.travels.Price"
        },
        "Currency": {
          "@Common.ValueList.CollectionPath": "Currencies",
          "@Common.ValueList.Label": "",
          "@Common.ValueList.Parameters": [
            {
              "$Type": "Common.ValueListParameterInOut",
              "LocalDataProperty": {
                "=": "Currency_code"
              },
              "ValueListProperty": "code"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "name"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "descr"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "symbol"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "minor"
            }
          ],
          "@title": "{i18n>CurrencyCode}",
          "type": "Currency"
        },
        "Supplements": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": {
            "elements": {
              "ID": {
                "key": true,
                "type": "cds.UUID"
              },
              "booked": {
                "type": "cds.Association",
                "target": "sap.capire.travels.flights.Supplements"
              },
              "Price": {
                "type": "sap.capire.travels.Price"
              },
              "Currency": {
                "type": "Currency"
              }
            }
          }
        },
        "BookingDate": {
          "@title": "{i18n>BookingDate}",
          "type": "cds.Date",
          "default": {
            "ref": [
              "$now"
            ]
          }
        }
      }
    },
    "sap.capire.travels.TravelAgencies": {
      "kind": "entity",
      "@title": "{i18n>TravelAgency}",
      "elements": {
        "ID": {
          "@title": "{i18n>Agency}",
          "@Common.Text": {
            "=": "Name"
          },
          "key": true,
          "type": "cds.String",
          "length": 6
        },
        "Name": {
          "@title": "{i18n>Agency}",
          "type": "cds.String",
          "length": 80
        },
        "Street": {
          "@title": "{i18n>Street}",
          "type": "cds.String",
          "length": 60
        },
        "PostalCode": {
          "@title": "{i18n>PostalCode}",
          "type": "cds.String",
          "length": 10
        },
        "City": {
          "@title": "{i18n>City}",
          "type": "cds.String",
          "length": 40
        },
        "Country": {
          "@Common.ValueList.CollectionPath": "Countries",
          "@Common.ValueList.Label": "",
          "@Common.ValueList.Parameters": [
            {
              "$Type": "Common.ValueListParameterInOut",
              "ValueListProperty": "code",
              "LocalDataProperty": {
                "=": "CountryCode_code"
              }
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "name"
            },
            {
              "$Type": "Common.ValueListParameterDisplayOnly",
              "ValueListProperty": "descr"
            }
          ],
          "@title": "{i18n>CountryCode}",
          "type": "Country"
        },
        "PhoneNumber": {
          "@title": "{i18n>PhoneNumber}",
          "type": "cds.String",
          "length": 30
        },
        "EMailAddress": {
          "@title": "{i18n>EMailAddress}",
          "type": "cds.String",
          "length": 256
        },
        "WebAddress": {
          "@title": "{i18n>WebAddress}",
          "type": "cds.String",
          "length": 256
        }
      }
    },
    "sap.capire.travels.TravelStatus": {
      "kind": "entity",
      "includes": [
        "sap.common.CodeList"
      ],
      "elements": {
        "code": {
          "@title": "{i18n>TravelStatus}",
          "@Common.Text": {
            "=": "name"
          },
          "@UI.ValueCriticality": [
            {
              "Criticality": {
                "#": "Positive"
              },
              "Value": "A"
            },
            {
              "Criticality": {
                "#": "Critical"
              },
              "Value": "O"
            },
            {
              "Criticality": {
                "#": "Critical"
              },
              "Value": "P"
            },
            {
              "Criticality": {
                "#": "Negative"
              },
              "Value": "B"
            },
            {
              "Criticality": {
                "#": "Negative"
              },
              "Value": "X"
            }
          ],
          "key": true,
          "type": "cds.String",
          "length": 1,
          "enum": {
            "Open": {
              "val": "O"
            },
            "InReview": {
              "val": "P"
            },
            "Blocked": {
              "val": "B"
            },
            "Accepted": {
              "val": "A"
            },
            "Rejected": {
              "val": "X"
            }
          }
        },
        "fieldControl": {
          "@odata.Type": "Edm.Byte",
          "type": "cds.Int16",
          "enum": {
            "Inapplicable": {
              "val": 0
            },
            "ReadOnly": {
              "val": 1
            },
            "Optional": {
              "val": 3
            },
            "Mandatory": {
              "val": 7
            }
          },
          "value": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "code"
                ]
              },
              "=",
              {
                "#": "Accepted"
              },
              "then",
              {
                "#": "ReadOnly"
              },
              "else",
              {
                "#": "Mandatory"
              },
              "end"
            ]
          }
        }
      }
    },
    "sap.capire.travels.Customers": {
      "kind": "entity",
      "@title": "{i18n>Customer}",
      "elements": {
        "ID": {
          "@title": "{i18n>Customer}",
          "@Common.Text": {
            "=": "Name"
          },
          "key": true,
          "type": "cds.String",
          "length": 10
        },
        "Name": {
          "@title": "{i18n>Name}",
          "type": "cds.String",
          "length": 80
        },
        "modifiedAt": {
          "type": "cds.Date"
        },
        "modifiedAtTime": {
          "type": "cds.Time"
        },
        "Travels": {
          "type": "cds.Association",
          "cardinality": {
            "max": "*"
          },
          "target": "sap.capire.travels.Travels",
          "on": [
            {
              "ref": [
                "Travels",
                "Customer"
              ]
            },
            "=",
            {
              "ref": [
                "$self"
              ]
            }
          ]
        }
      }
    },
