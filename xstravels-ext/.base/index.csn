      "@UI.PresentationVariant.Visualizations": [
        "@UI.LineItem"
      ],
      "@UI.SelectionFields": [],
      "elements": {
        "Travel": {
          "@mandatory": true
        },
        "Flight": {
          "@Common.FieldControl": {
            "=": "Travel.Status.fieldControl"
          },
          "@mandatory": true,
          "elements": {
            "date": {
              "@assert": {
                "xpr": [
                  "case",
                  "when",
                  {
                    "ref": [
                      "date"
                    ]
                  },
                  "not",
                  "between",
                  {
                    "ref": [
                      "$self",
                      "Travel",
                      "BeginDate"
                    ]
                  },
                  "and",
                  {
                    "ref": [
                      "$self",
                      "Travel",
                      "EndDate"
                    ]
                  },
                  "then",
                  {
                    "val": "ASSERT_BOOKING_IN_TRAVEL_PERIOD"
                  },
                  "end"
                ]
              }
            }
          }
        },
        "FlightPrice": {
          "@Common.FieldControl": {
            "=": "Travel.Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "FlightPrice"
                ]
              },
              "<",
              {
                "val": 0
              },
              "then",
              {
                "val": "ASSERT_FLIGHT_PRICE_POSITIVE"
              },
              "end"
            ]
          }
        },
        "Currency": {
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "Currency"
                ]
              },
              "!=",
              {
                "ref": [
                  "Travel",
                  "Currency"
                ]
              },
              "then",
              {
                "val": "ASSERT_BOOKING_CURRENCY_MATCHES_TRAVEL"
              },
              "end"
            ]
          }
        },
        "BookingDate": {
          "@Core.Computed": true,
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "BookingDate"
                ]
              },
              ">",
              {
                "ref": [
                  "Travel",
                  "EndDate"
                ]
              },
              "then",
              {
                "val": "ASSERT_NO_BOOKINGS_AFTER_TRAVEL"
              },
              "end"
            ]
          }
        }
      }
    },
