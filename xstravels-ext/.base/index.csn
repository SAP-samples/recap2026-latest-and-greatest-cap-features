    {
      "annotate": "TravelService.Travels",
      "elements": {
        "Description": {
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "Description"
                ]
              },
              "is",
              "null",
              "then",
              {
                "val": "Description is required"
              },
              "when",
              {
                "func": "length",
                "args": [
                  {
                    "func": "trim",
                    "args": [
                      {
                        "ref": [
                          "Description"
                        ]
                      }
                    ]
                  }
                ]
              },
              "<",
              {
                "val": 3
              },
              "then",
              {
                "val": "Description is too short"
              },
              "end"
            ]
          }
        },
        "BeginDate": {
          "@Common.FieldControl": {
            "=": "Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "EndDate"
                ]
              },
              "<",
              {
                "ref": [
                  "BeginDate"
                ]
              },
              "then",
              {
                "val": "ASSERT_BEGINDATE_BEFORE_ENDDATE"
              },
              "when",
              "exists",
              {
                "ref": [
                  {
                    "id": "Bookings",
                    "where": [
                      {
                        "ref": [
                          "Flight",
                          "date"
                        ]
                      },
                      "<",
                      {
                        "ref": [
                          "Travel",
                          "BeginDate"
                        ]
                      }
                    ]
                  }
                ]
              },
              "then",
              {
                "val": "ASSERT_BOOKINGS_IN_TRAVEL_PERIOD"
              },
              "end"
            ]
          },
          "@mandatory": true
        },
        "EndDate": {
          "@Common.FieldControl": {
            "=": "Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "EndDate"
                ]
              },
              "<",
              {
                "ref": [
                  "BeginDate"
                ]
              },
              "then",
              {
                "val": "ASSERT_ENDDATE_AFTER_BEGINDATE"
              },
              "when",
              "exists",
              {
                "ref": [
                  {
                    "id": "Bookings",
                    "where": [
                      {
                        "ref": [
                          "Flight",
                          "date"
                        ]
                      },
                      ">",
                      {
                        "ref": [
                          "Travel",
                          "EndDate"
                        ]
                      }
                    ]
                  }
                ]
              },
              "then",
              {
                "val": "ASSERT_BOOKINGS_IN_TRAVEL_PERIOD"
              },
              "end"
            ]
          },
          "@mandatory": true
        },
        "BookingFee": {
          "@Common.FieldControl": {
            "=": "Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "BookingFee"
                ]
              },
              "<",
              {
                "val": 0
              },
              "then",
              {
                "val": "ASSERT_BOOKING_FEE_NON_NEGATIVE"
              },
              "end"
            ]
          }
        },
        "Agency": {
          "@Common.FieldControl": {
            "=": "Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              "not",
              "exists",
              {
                "ref": [
                  "Agency"
                ]
              },
              "then",
              {
                "val": "Agency does not exist"
              },
              "end"
            ]
          },
          "@mandatory": true
        },
        "Customer": {
          "@Common.FieldControl": {
            "=": "Status.fieldControl"
          },
          "@assert": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "Customer"
                ]
              },
              "is",
              "null",
              "then",
              {
                "val": "Customer must be specified"
              },
              "when",
              "not",
              "exists",
              {
                "ref": [
                  "Customer"
                ]
              },
              "then",
              {
                "val": "Customer does not exist"
              },
              "end"
            ]
          }
        }
      }
    }
