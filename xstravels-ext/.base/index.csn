          },
          {
            "ref": [
              "Description"
            ]
          }
        ]
      }
    },
    "TravelService": {
      "kind": "service",
      "@fiori": true
    },
    "TravelService.Travels": {
      "kind": "entity",
      "@restrict": [
        {
          "grant": "READ",
          "to": "authenticated-user"
        },
        {
          "grant": [
            "rejectTravel",
            "acceptTravel",
            "deductDiscount"
          ],
          "to": "reviewer"
        },
        {
          "grant": [
            "*"
          ],
          "to": "processor"
        },
        {
          "grant": [
            "*"
          ],
          "to": "admin"
        }
      ],
      "@flow.status": {
        "=": "Status"
      },
      "@odata.draft.enabled": true,
      "@Common.SemanticKey": [
        {
          "=": "ID"
        }
      ],
      "@Common.SideEffects.SourceProperties": [
        {
          "=": "BookingFee"
        }
      ],
      "@Common.SideEffects.TargetProperties": [
        "TotalPrice"
      ],
      "@Common.SideEffects#ReactonItemCreationOrDeletion.SourceEntities": [
        {
          "=": "Bookings"
        }
      ],
      "@Common.SideEffects#ReactonItemCreationOrDeletion.TargetProperties": [
        "TotalPrice"
      ],
      "@UI.Identification": [
        {
          "$Type": "UI.DataFieldForAction",
          "Action": "TravelService.deductDiscount",
          "Label": "{i18n>DeductDiscount}"
        }
      ],
      "@UI.HeaderInfo.TypeName": "{i18n>Travel}",
      "@UI.HeaderInfo.TypeNamePlural": "{i18n>Travels}",
      "@UI.HeaderInfo.Title.Value": {
        "=": "Description"
      },
      "@UI.HeaderInfo.Description.Value": {
        "=": "ID"
      },
      "@UI.PresentationVariant.Text": "Default",
      "@UI.PresentationVariant.Visualizations": [
        "@UI.LineItem"
      ],
      "@UI.PresentationVariant.SortOrder": [
        {
          "Property": {
            "=": "ID"
          },
          "Descending": true
        }
      ],
      "@UI.SelectionFields": [
        {
          "ref": [
            "Agency",
            "ID"
          ]
        },
        {
          "ref": [
            "Customer",
            "ID"
          ]
        },
        {
          "ref": [
            "Status",
            "code"
          ]
        }
      ],
      "@UI.LineItem": [
        {
          "$Type": "UI.DataFieldForAction",
          "Action": "TravelService.deductDiscount",
          "Label": "{i18n>DeductDiscount}"
        },
        {
          "Value": {
            "=": "ID"
          },
          "@UI.Importance": {
            "#": "High"
          }
        },
        {
          "Value": {
            "=": "Description"
          },
          "@UI.Importance": {
            "#": "High"
          }
        },
        {
          "Value": {
            "ref": [
              "Customer",
              "ID"
            ]
          },
          "@UI.Importance": {
            "#": "High"
          },
          "@HTML5.CssDefaults": {
            "width": "14em"
          }
        },
        {
          "Value": {
            "ref": [
              "Agency",
              "ID"
            ]
          },
          "@HTML5.CssDefaults": {
            "width": "16em"
          }
        },
        {
          "Value": {
            "=": "BeginDate"
          },
          "@HTML5.CssDefaults": {
            "width": "9em"
          }
        },
        {
          "Value": {
            "=": "EndDate"
          },
          "@HTML5.CssDefaults": {
            "width": "9em"
          }
        },
        {
          "Value": {
            "=": "BookingFee"
          },
          "@HTML5.CssDefaults": {
            "width": "10em"
          }
        },
        {
          "Value": {
            "=": "TotalPrice"
          },
          "@HTML5.CssDefaults": {
            "width": "12em"
          }
        },
        {
          "Value": {
            "ref": [
              "Status",
              "code"
            ]
          },
          "@UI.Importance": {
            "#": "High"
          },
          "@HTML5.CssDefaults": {
            "width": "10em"
          },
          "Criticality": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Accepted"
              },
              "then",
              {
                "val": 3
              },
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Blocked"
              },
              "then",
              {
                "val": 2
              },
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Rejected"
              },
              "then",
              {
                "val": 1
              },
              "else",
              {
                "val": 0
              },
              "end"
            ]
          }
        }
      ],
      "@UI.Facets": [
        {
          "$Type": "UI.ReferenceFacet",
          "Target": "@UI.FieldGroup#TravelData",
          "Label": "{i18n>GeneralInformation}"
        },
        {
          "$Type": "UI.ReferenceFacet",
          "Target": "Bookings/@UI.PresentationVariant",
          "Label": "{i18n>Bookings}"
        }
      ],
      "@UI.FieldGroup#TravelData.Data": [
        {
          "Value": {
            "ref": [
              "Customer",
              "ID"
            ]
          }
        },
        {
          "Value": {
            "ref": [
              "Agency",
              "ID"
            ]
          }
        },
        {
          "Value": {
            "=": "Description"
          }
        },
        {
          "Value": {
            "=": "Status.code"
          },
          "Criticality": {
            "xpr": [
              "case",
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Accepted"
              },
              "then",
              {
                "val": 3
              },
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Blocked"
              },
              "then",
              {
                "val": 2
              },
              "when",
              {
                "ref": [
                  "Status",
                  "code"
                ]
              },
              "==",
              {
                "#": "Rejected"
              },
              "then",
              {
                "val": 1
              },
              "else",
              {
                "val": 0
              },
              "end"
            ]
          }
        },
        {
          "Value": {
            "=": "BeginDate"
          }
        },
        {
          "Value": {
            "=": "EndDate"
          }
        },
        {
          "Value": {
            "=": "BookingFee"
          }
        },
        {
          "Value": {
            "=": "TotalPrice"
          }
        }
      ],
      "projection": {
        "from": {
          "ref": [
            "sap.capire.travels.Travels"
          ]
        }
      },
      "actions": {
        "deductDiscount": {
          "kind": "action",
          "@from": [
            {
              "#": "Open"
            }
          ],
          "@title": "{i18n>DeductDiscount}",
          "@Common.SideEffects.TargetProperties": [
            "in/TotalPrice",
            "in/BookingFee"
          ],
          "params": {
            "percent": {
              "type": "Percentage",
              "notNull": true
            }
          },
          "returns": {
            "type": "TravelService.Travels"
          }
        },
        "acceptTravel": {
          "kind": "action",
          "@from": [
            {
              "#": "InReview"
            }
          ],
          "@to": {
            "#": "Accepted"
          },
          "@title": "{i18n>Accept}"
        },
        "rejectTravel": {
          "kind": "action",
          "@from": [
            {
              "#": "InReview"
            }
          ],
          "@to": {
            "#": "Rejected"
          },
          "@title": "{i18n>Reject}"
        },
        "reopenTravel": {
          "kind": "action",
          "@from": [
            {
              "#": "Rejected"
            },
            {
              "#": "Accepted"
            }
          ],
          "@to": {
            "#": "Open"
          },
          "@title": "{i18n>Reopen}"
        },
        "submitForReview": {
          "kind": "action",
          "@from": [
            {
              "#": "Open"
            }
          ],
          "@to": {
            "#": "InReview"
          }
        }
      }
    },
    "TravelService.TravelAgencies": {
      "kind": "entity",
